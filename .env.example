# Supabase survey storage
# Set the same values in Netlify -> Site configuration -> Environment variables
SUPABASE_URL=

# Recommended: use a server-only secret key from Supabase project settings.
# Do not use the anon / publishable key here.
SUPABASE_SECRET_KEY=

# Optional legacy fallback if you prefer the older key name instead.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: defaults to survey_responses
SUPABASE_SURVEY_TABLE=survey_responses

# Shared password for the private /survey-responses page
SURVEY_RESPONSES_PASSWORD=
